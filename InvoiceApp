    private void refreshTableData() {
        tableModel.setRowCount(0); 
        double totalCollected = 0, totalOutstanding = 0;

        for (Invoice inv : manager.getAllInvoices()) {
            double balance = inv.getAmount() - inv.getAmountPaid();

            Object[] row = {
                    inv.getDate(), inv.getInvoiceId(), inv.getJobNo(), 
                    inv.getCustomerName(), inv.getDescription(), 
                    String.format("%.2f", inv.getAmount()),        
                    String.format("%.2f", inv.getAmountPaid()),    
                    String.format("%.2f", balance),                
                    inv.getStatus(), inv.getPaidDate(), inv.getRemark()
                };
            tableModel.addRow(row);
            totalCollected += inv.getAmountPaid();
            totalOutstanding += balance;
        }

        totalPaidLabel.setText(String.format("Total Collected: RM %.2f  |  ", totalCollected));
        totalUnpaidLabel.setText(String.format("Total Outstanding: RM %.2f", totalOutstanding));
    }

    private void setupTableColors() {
        table.getColumnModel().getColumn(8).setCellRenderer(new javax.swing.table.DefaultTableCellRenderer() {
                @Override
                public Component getTableCellRendererComponent(JTable table, Object value, boolean isSelected, boolean hasFocus, int row, int column) {
                    Component c = super.getTableCellRendererComponent(table, value, isSelected, hasFocus, row, column);
                    if ("Paid".equals(value)) {
                        c.setForeground(new Color(0, 150, 0)); 
                        c.setFont(c.getFont().deriveFont(Font.BOLD));
                    } else if ("Partial".equals(value)) {
                        c.setForeground(new Color(255, 120, 0)); 
                        c.setFont(c.getFont().deriveFont(Font.BOLD));
                    } else if ("Unpaid".equals(value)) {
                        c.setForeground(Color.RED); 
                        c.setFont(c.getFont().deriveFont(Font.BOLD));
                    } else {
                        c.setForeground(Color.BLACK); 
                        c.setFont(table.getFont());
                    }
                    if (isSelected) c.setForeground(table.getSelectionForeground());
                    return c;
                }
            });
    }

    private void applyZoom() {
        updateComponentFont(frame, currentFontSize);
        table.setRowHeight(currentFontSize + 10);
        table.getTableHeader().setFont(new Font("SansSerif", Font.BOLD, currentFontSize));

        // 1. Scale the INVOICE title dynamically (Makes it 3x bigger than normal text!)
        if (titleLabel != null) {
            titleLabel.setFont(new Font("SansSerif", Font.BOLD, currentFontSize * 2)); 
        }

        // 2. Scale the Logo Image dynamically (Now supports 150x50 Rectangles!)
        if (logoLabel != null && originalLogo != null) {

            // Calculate how much we have zoomed in compared to the default size (14)
            double scaleFactor = (double) currentFontSize / 14.0; 

            // Apply that zoom multiplier to your specific 150x50 dimensions
            int currentWidth = (int) (150 * scaleFactor);
            int currentHeight = (int) (50 * scaleFactor);

            Image scaledImage = originalLogo.getImage().getScaledInstance(currentWidth, currentHeight, Image.SCALE_SMOOTH);
            logoLabel.setIcon(new ImageIcon(scaledImage));
        }

        frame.revalidate();
        frame.repaint();
    }

    private void updateComponentFont(Component comp, int newSize) {
        
        if (comp == titleLabel || comp == logoLabel) {
            return; 
        }

        Font currentFont = comp.getFont();
        if (currentFont != null) {
            comp.setFont(new Font(currentFont.getName(), currentFont.getStyle(), newSize));
        }
        if (comp instanceof Container) {
            for (Component child : ((Container) comp).getComponents()) {
                updateComponentFont(child, newSize); 
            }
        }
    }
    //dropdown for customer selection so no need to rewrite the same customer
    private JComboBox<String> createCustomerDropdown(String preSelectedCustomer) {
        JComboBox<String> box = new JComboBox<>();
        for (String c : manager.getCustomers()) box.addItem(c);
        box.addItem("+ Add New Customer");

        if (preSelectedCustomer != null && !preSelectedCustomer.trim().isEmpty()) {
            boolean found = false;
            for (int i = 0; i < box.getItemCount(); i++) {
                if (preSelectedCustomer.equals(box.getItemAt(i))) {
                    box.setSelectedIndex(i);
                    found = true;
                    break;
                }
            }
            //add one default customer to not crash the program if no customer found
            if (!found) {
                box.insertItemAt(preSelectedCustomer, 0); 
                box.setSelectedItem(preSelectedCustomer);
            }
        }

        box.addActionListener(e -> {
                    if ("+ Add New Customer".equals(box.getSelectedItem())) {
                        String newCust = JOptionPane.showInputDialog(frame, "Enter New Customer Name:");
                        if (newCust != null && !newCust.trim().isEmpty()) {
                            newCust = newCust.trim();
                            manager.addCustomer(newCust); 
                            box.removeItem("+ Add New Customer");
                            box.addItem(newCust);
                            box.addItem("+ Add New Customer");
                            box.setSelectedItem(newCust); 
                        } else {
                            box.setSelectedIndex(0); 
                        }
                    }
            });
        return box;
    }
    //add calendar function
    private JDatePickerImpl createVisualDatePicker(String existingDate) {
        UtilDateModel model = new UtilDateModel();
        if (existingDate != null && !existingDate.trim().isEmpty() && !existingDate.equals("-")) {
            try {
                String[] parts = existingDate.split("/");
                int day = Integer.parseInt(parts[0]);
                int month = Integer.parseInt(parts[1]) - 1; 
                int year = Integer.parseInt(parts[2]);
                model.setDate(year, month, day);
                model.setSelected(true);
            } catch (Exception e) {}
        }
        Properties p = new Properties();
        p.put("text.today", "Today");
        p.put("text.month", "Month");
        p.put("text.year", "Year");
        JDatePanelImpl datePanel = new JDatePanelImpl(model, p);
        return new JDatePickerImpl(datePanel, new DateLabelFormatter()); 
    }

