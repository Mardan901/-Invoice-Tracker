                public void keyReleased(KeyEvent e) {
                    String text = searchField.getText();
                    if (text.trim().length() == 0) sorter.setRowFilter(null);
                    else sorter.setRowFilter(RowFilter.regexFilter("(?i)" + text));
                }
            });

